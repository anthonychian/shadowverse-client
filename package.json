{
  "name": "shadowverse-client",
  "version": "0.1.0",
  "engines": {
    "node": "22.18.0"
  },
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.6",
    "@mui/joy": "^5.0.0-beta.6",
    "@mui/material": "^5.15.6",
    "@react-spring/three": "^9.7.3",
    "@react-spring/web": "^9.7.3",
    "@react-three/drei": "^9.92.5",
    "@react-three/fiber": "^8.15.13",
    "@reduxjs/toolkit": "^2.0.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@use-gesture/react": "^10.3.0",
    "caniuse-lite": "^1.0.30001749",
    "framer-motion": "^10.18.0",
    "html2canvas": "^1.4.1",
    "object-hash": "^3.0.0",
    "perfect-arrows": "^0.3.7",
    "pixi-spine": "^4.0.6",
    "pixi.js": "^7.4.3",
    "r3f-form": "^3.0.2",
    "react": "^18.2.0",
    "react-dice-roll": "^1.2.2",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.4.6",
    "react-infinite-scroll-component": "^6.1.0",
    "react-lazy-load-image-component": "^1.6.2",
    "react-native-animated-border": "^1.0.2",
    "react-redux": "^9.0.4",
    "react-router-dom": "^6.21.3",
    "react-scripts": "5.0.1",
    "redux-persist": "^6.0.0",
    "socket.io-client": "^4.8.1",
    "sve-engine": "file:packages/sve-engine",
    "three": "^0.159.0",
    "web-vitals": "^2.1.4"
  },
  "workspaces": [
    "packages/sve-engine",
    "server"
  ],
  "scripts": {
    "start": "react-scripts start",
    "build": "npm run build:engine && react-scripts build",
    "build:engine": "npm run build -w sve-engine && node src/scripts/sync-card-stats.js",
    "sync:cards": "node src/scripts/backfill-reprints.js",
    "test": "react-scripts test",
    "test:engine": "npm run test -w sve-engine",
    "server": "npm run start -w shadowverse-server",
    "build:server": "npm run build -w sve-engine",
    "merge:cards": "node src/scripts/mergecards.js",
    "scrape:decks": "node src/scripts/scrapecardnos.js --file src/scripts/deck-lists/festive-sword.json src/scripts/deck-lists/abyss-machina.json",
    "regenerate:deck-cards": "node src/scripts/regenerate-deck-cards.js",
    "resync:decks": "npm run scrape:decks && npm run regenerate:deck-cards && npm run sync:cards",
    "parse:dsl": "node src/scripts/parse-effects-to-dsl.js",
    "rollout:set": "node src/scripts/rollout-set.js",
    "rollout:all": "node src/scripts/rollout-all-expansions.js",
    "coverage:cards": "node src/scripts/card-coverage.js",
    "eval:card": "node src/scripts/eval-card.js",
    "eval:scenarios": "node src/scripts/eval-card.js --validate-scenarios",
    "generate:manifest": "node src/scripts/generate-manifest.js",
    "fix:review-stubs": "node src/scripts/fix-review-stubs.js && node src/scripts/regenerate-deck-cards.js && node src/scripts/generate-manifest.js",
    "fix:all-noops": "node src/scripts/fix-all-noops.js && node src/scripts/generate-manifest.js",
    "complete:cards": "node src/scripts/complete-all-cards.js",
    "verify:cards": "node src/scripts/verify-all-cards.js",
    "audit:dsl": "node src/scripts/audit-dsl-correctness.js",
    "report:noop-labels": "node src/scripts/report-noop-labels.js",
    "auto:fix-noops": "node src/scripts/auto-fix-noop-loop.js",
    "auto:resolve-noops": "node src/scripts/auto-resolve-noop-labels.js",
    "apply:timing-stubs": "node src/scripts/apply-timing-stubs.js",
    "sync:eval-status": "node src/scripts/sync-eval-status.js",
    "generate:scenario-stub": "node src/scripts/generate-scenario-stub.js",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "react-hooks/exhaustive-deps": "off",
      "no-unused-vars": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "react-refresh": "^0.11.0",
    "upng-js": "^2.1.0"
  }
}
